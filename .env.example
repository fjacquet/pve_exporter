# Copy to .env and fill in. .env is gitignored; config.yaml is the source of truth.
# Create a read-only API token in PVE: Datacenter > Permissions > API Tokens,
# grant the token (or its user) the PVEAuditor role at path "/".

PVE1_HOST=10.0.0.1:8006
PVE1_TOKEN_ID=exporter@pam!prometheus
PVE1_TOKEN_SECRET=00000000-0000-0000-0000-000000000000
