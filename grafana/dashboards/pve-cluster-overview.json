{
  "uid": "pve-cluster-overview",
  "title": "PVE Cluster Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["proxmox", "pve", "cluster"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(pve_up, cluster)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Health & Status",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Nodes Online",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_up{id=~\"node/.*\", cluster=~\"$cluster\"})",
          "legendFormat": "Online",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Guests Running",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_up{id=~\"(qemu|lxc)/.*\", cluster=~\"$cluster\"})",
          "legendFormat": "Running",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Storages Available",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_up{id=~\"storage/.*\", cluster=~\"$cluster\"})",
          "legendFormat": "Available",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Replication Failures",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_replication_failed_syncs{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Guests Not Backed Up",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_not_backed_up_total{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Not Backed Up",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Subscription Active",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "mappings": [
          { "options": { "0": { "text": "No" }, "1": { "text": "Yes" } }, "type": "value" }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "min(pve_subscription_status{status=\"active\", cluster=~\"$cluster\"})",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Capacity",
      "id": 10,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Memory Used % (per node)",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(pve_memory_usage_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} / pve_memory_size_bytes{id=~\"node/.*\",cluster=~\"$cluster\"}) * on(cluster,id) group_left(name) pve_node_info",
          "legendFormat": "{{name}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Storage Used %",
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 8, "y": 6, "w": 8, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(pve_disk_usage_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"} / pve_disk_size_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"}) * on(cluster,id) group_left(storage,node) pve_storage_info",
          "legendFormat": "{{node}}/{{storage}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "CPU Overcommit",
      "id": 13,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_cpu_usage_limit{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"}) / sum(pve_cpu_usage_limit{id=~\"node/.*\",cluster=~\"$cluster\"})",
          "legendFormat": "Overcommit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Activity",
      "id": 20,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Node CPU",
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (id, name)(pve_cpu_usage_ratio{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node Memory Used/Total",
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_memory_usage_bytes{id=~\"node/.*\",cluster=~\"$cluster\"})",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_memory_size_bytes{id=~\"node/.*\",cluster=~\"$cluster\"})",
          "legendFormat": "Total",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cluster Network I/O",
      "id": 23,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(pve_network_receive_bytes_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "Receive",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(pve_network_transmit_bytes_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "Transmit",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cluster Disk I/O",
      "id": 24,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(pve_disk_read_bytes_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "Read",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(pve_disk_written_bytes_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "Written",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Inventory",
      "id": 30,
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Nodes",
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 10 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cpu%" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "mem%" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "uptime" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "cluster": true,
              "cluster 1": true,
              "cluster 2": true,
              "cluster 3": true,
              "cluster 4": true,
              "cluster 5": true,
              "name 2": true,
              "name 3": true,
              "name 4": true,
              "name 5": true,
              "Value #info": true
            },
            "renameByName": {
              "name": "name",
              "name 1": "name",
              "Value #A": "status",
              "Value #B": "cpu%",
              "Value #C": "mem%",
              "Value #D": "uptime"
            },
            "indexByName": {
              "name": 0,
              "status": 1,
              "cpu%": 2,
              "mem%": 3,
              "uptime": 4
            }
          }
        }
      ],
      "links": [
        {
          "title": "Node Details",
          "url": "/d/pve-node?var-node=${__data.fields.name}&var-cluster=${cluster}",
          "targetBlank": false
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_node_info{cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "info",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_up{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info",
          "legendFormat": "{{name}}",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_cpu_usage_ratio{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info",
          "legendFormat": "{{name}}",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(pve_memory_usage_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} / pve_memory_size_bytes{id=~\"node/.*\",cluster=~\"$cluster\"}) * on(cluster,id) group_left(name) pve_node_info",
          "legendFormat": "{{name}}",
          "refId": "C",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_uptime_seconds{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info",
          "legendFormat": "{{name}}",
          "refId": "D",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "table",
      "title": "Top Guests by CPU",
      "id": 32,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 10 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cpu%" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "cluster": true,
              "cluster 1": true,
              "cluster 2": true,
              "node 2": true,
              "name 2": true,
              "tags 2": true,
              "Value #info": true
            },
            "renameByName": {
              "name": "name",
              "name 1": "name",
              "node": "node",
              "node 1": "node",
              "Value #A": "cpu%"
            },
            "indexByName": {
              "name": 0,
              "node": 1,
              "cpu%": 2
            }
          }
        }
      ],
      "links": [
        {
          "title": "Guest Details",
          "url": "/d/pve-guest?var-guest=${__data.fields.name}&var-cluster=${cluster}",
          "targetBlank": false
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_guest_info{cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "info",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "topk(10, pve_cpu_usage_ratio{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name,node) pve_guest_info)",
          "legendFormat": "{{name}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
