{
  "uid": "pve-node",
  "title": "PVE Node Detail",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["proxmox", "pve", "node"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(pve_up, cluster)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(pve_node_info{cluster=~\"$cluster\"}, name)",
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Node Status",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Node Up",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "mappings": [
          { "options": { "0": { "text": "Down" }, "1": { "text": "Up" } }, "type": "value" }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(pve_up{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "Up",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "CPU Usage",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 3, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg(pve_cpu_usage_ratio{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Memory Used",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg(pve_memory_usage_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "Used",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Memory Total",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 9, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg(pve_memory_size_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Root Disk Used %",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg((pve_disk_usage_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} / pve_disk_size_bytes{id=~\"node/.*\",cluster=~\"$cluster\"}) * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Uptime",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 15, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg(pve_uptime_seconds{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Guest Count",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 18, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(pve_guest_info{node=~\"$node\",cluster=~\"$cluster\"})",
          "legendFormat": "Guests",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Subscription Days to Due",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 21, "y": 1, "w": 3, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "((pve_subscription_next_due_timestamp_seconds{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"}) - time()) / 86400",
          "legendFormat": "Days to Due",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PVE Version",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 5, "w": 6, "h": 3 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_version_info{cluster=~\"$cluster\"} * on(cluster) group_left(release) pve_version_info{cluster=~\"$cluster\"}",
          "legendFormat": "{{release}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Activity",
      "id": 20,
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (id, name)(pve_cpu_usage_ratio{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Used vs Total",
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (id, name)(pve_memory_usage_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "{{name}} Used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (id, name)(pve_memory_size_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "{{name}} Total",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Root Disk Usage",
      "id": 23,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (id, name)(pve_disk_usage_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "{{name}} Used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (id, name)(pve_disk_size_bytes{id=~\"node/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "{{name}} Total",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network I/O",
      "id": 24,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(pve_network_receive_bytes_total{id=~\"node/.*\",cluster=~\"$cluster\"}[5m]) * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "Receive",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(pve_network_transmit_bytes_total{id=~\"node/.*\",cluster=~\"$cluster\"}[5m]) * on(cluster,id) group_left(name) pve_node_info{name=~\"$node\"})",
          "legendFormat": "Transmit",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Guests on Node",
      "id": 30,
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Guests on Node",
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 12 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cpu%" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "mem%" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "uptime" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "Time 6": true,
              "cluster": true,
              "cluster 1": true,
              "cluster 2": true,
              "cluster 3": true,
              "cluster 4": true,
              "cluster 5": true,
              "cluster 6": true,
              "node 2": true,
              "node 3": true,
              "node 4": true,
              "node 5": true,
              "node 6": true,
              "name 2": true,
              "name 3": true,
              "name 4": true,
              "name 5": true,
              "name 6": true,
              "tags 2": true,
              "tags 3": true,
              "tags 4": true,
              "tags 5": true,
              "tags 6": true
            },
            "renameByName": {
              "name": "name",
              "name 1": "name",
              "node": "node",
              "node 1": "node",
              "tags": "tags",
              "tags 1": "tags",
              "Value #A": "running",
              "Value #B": "cpu%",
              "Value #C": "mem%",
              "Value #D": "uptime",
              "Value #E": "onboot"
            },
            "indexByName": {
              "name": 0,
              "node": 1,
              "running": 2,
              "cpu%": 3,
              "mem%": 4,
              "uptime": 5,
              "onboot": 6,
              "tags": 7
            }
          }
        }
      ],
      "links": [
        {
          "title": "Guest Details",
          "url": "/d/pve-guest?var-guest=${__data.fields.name}&var-cluster=${cluster}",
          "targetBlank": false
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_guest_info{node=~\"$node\",cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "info",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_up{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name,node) pve_guest_info{node=~\"$node\",cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_cpu_usage_ratio{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name,node) pve_guest_info{node=~\"$node\",cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(pve_memory_usage_bytes{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} / pve_memory_size_bytes{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"}) * on(cluster,id) group_left(name,node) pve_guest_info{node=~\"$node\",cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "C",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_uptime_seconds{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name,node) pve_guest_info{node=~\"$node\",cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "D",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_onboot_status{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name,node) pve_guest_info{node=~\"$node\",cluster=~\"$cluster\"}",
          "legendFormat": "{{name}}",
          "refId": "E",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
