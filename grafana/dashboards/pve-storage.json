{
  "uid": "pve-storage",
  "title": "PVE Storage",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["proxmox", "pve", "storage"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(pve_up, cluster)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Summary",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total capacity",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_disk_size_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"})",
          "legendFormat": "Total capacity",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total used",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_disk_usage_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"})",
          "legendFormat": "Total used",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Shared storages",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_storage_shared{cluster=~\"$cluster\"})",
          "legendFormat": "Shared storages",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Storage Inventory",
      "id": 5,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Storages",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 10 },
      "options": {
        "sortBy": [{ "displayName": "Storage", "desc": false }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Used %" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 0.8 },
                    { "color": "red", "value": 0.9 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_disk_usage_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_disk_size_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_storage_shared{id=~\"storage/.*\",cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_up{id=~\"storage/.*\",cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_disk_usage_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"} / pve_disk_size_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_storage_info{cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "F"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "Time 6": true,
              "Value #F": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "__name__ 5": true,
              "__name__ 6": true,
              "cluster": true,
              "cluster 1": true,
              "cluster 2": true,
              "cluster 3": true,
              "cluster 4": true,
              "cluster 5": true,
              "cluster 6": true
            },
            "renameByName": {
              "storage": "Storage",
              "node": "Node",
              "plugintype": "Plugin Type",
              "content": "Content",
              "Value #A": "Used",
              "Value #B": "Size",
              "Value #C": "Shared",
              "Value #D": "Up",
              "Value #E": "Used %"
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Usage",
      "id": 7,
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Used % per storage",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(pve_disk_usage_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"} / pve_disk_size_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"}) * on(cluster,id) group_left(storage,node) pve_storage_info",
          "legendFormat": "{{storage}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Trends",
      "id": 9,
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Used vs Size per storage",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_disk_usage_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(storage) pve_storage_info",
          "legendFormat": "{{storage}} used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_disk_size_bytes{id=~\"storage/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(storage) pve_storage_info",
          "legendFormat": "{{storage}} size",
          "refId": "B"
        }
      ]
    }
  ]
}
