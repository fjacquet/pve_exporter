{
  "uid": "pve-ha-quorum",
  "title": "PVE HA & Quorum",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["proxmox", "pve", "ha", "quorum"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(pve_up, cluster)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Cluster Status",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Nodes Online",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_up{id=~\"node/.*\",cluster=~\"$cluster\"})",
          "legendFormat": "Online",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "QDevice Up",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "mappings": [
          {
            "type": "value",
            "options": {
              "0": { "text": "Down", "color": "red" },
              "1": { "text": "Up", "color": "green" }
            }
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_qdevice_up{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "QDevice",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Cluster Info",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 8, "y": 1, "w": 16, "h": 4 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "quorate" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "No quorum", "color": "red", "index": 0 },
                      "1": { "text": "Quorate", "color": "green", "index": 1 }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "cluster": true,
              "id": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "nodes": "nodes",
              "quorate": "quorate",
              "version": "version"
            },
            "indexByName": {
              "nodes": 0,
              "quorate": 1,
              "version": 2
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_cluster_info{cluster=~\"$cluster\"}",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "QDevice",
      "id": 10,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "QDevice Info",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 5 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "cluster": true,
              "id": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "model": "model",
              "host": "host",
              "algorithm": "algorithm"
            },
            "indexByName": {
              "model": 0,
              "host": 1,
              "algorithm": 2
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_qdevice_info{cluster=~\"$cluster\"}",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "High Availability",
      "id": 20,
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "state-timeline",
      "title": "HA-Managed Guest States",
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "center",
        "rowHeight": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "off", "color": "blue", "index": 0 },
                "1": { "text": "active", "color": "green", "index": 1 }
              }
            }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_ha_state{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name) pve_guest_info",
          "legendFormat": "{{name}} {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Current HA State per Guest",
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "cluster": true,
              "id": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "name": "name",
              "node": "node",
              "state": "state"
            },
            "indexByName": {
              "name": 0,
              "node": 1,
              "state": 2
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(pve_ha_state{id=~\"(qemu|lxc)/.*\",cluster=~\"$cluster\"} * on(cluster,id) group_left(name,node) pve_guest_info) == 1",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Node Membership",
      "id": 30,
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Node Membership",
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 8 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "online" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "Offline", "color": "red", "index": 0 },
                      "1": { "text": "Online", "color": "green", "index": 1 }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "cluster 1": true,
              "cluster 2": true,
              "id": true,
              "job 1": true,
              "job 2": true,
              "instance 1": true,
              "instance 2": true,
              "Value #A": true
            },
            "renameByName": {
              "name": "name",
              "nodeid": "nodeid",
              "level": "level",
              "Value #B": "online"
            },
            "indexByName": {
              "name": 0,
              "nodeid": 1,
              "level": 2,
              "Value #B": 3
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_node_info{cluster=~\"$cluster\"}",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_up{id=~\"node/.*\",cluster=~\"$cluster\"}",
          "legendFormat": "",
          "refId": "B",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
