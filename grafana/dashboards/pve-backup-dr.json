{
  "uid": "pve-backup-dr",
  "title": "PVE Backup & DR",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["proxmox", "pve", "backup", "dr", "replication"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(pve_up, cluster)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Backup Status",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Not Backed Up",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_not_backed_up_total{cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Not Backed Up",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Guests Not Backed Up",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 1, "w": 18, "h": 8 },
      "options": {
        "sortBy": [{ "displayName": "Guest", "desc": false }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_not_backed_up_info{cluster=~\"$cluster\"} * on(cluster,id) group_left(name,node) pve_guest_info",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster": true,
              "Value #A": true
            },
            "renameByName": {
              "id": "Guest",
              "name": "Name",
              "node": "Node"
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Replication",
      "id": 4,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Failed Syncs Total",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 10, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(pve_replication_failed_syncs{cluster=~\"$cluster\"})",
          "legendFormat": "Failed Syncs",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Max Replication Age",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 10, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3600 },
              { "color": "red", "value": 86400 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(time() - pve_replication_last_sync_timestamp_seconds{cluster=~\"$cluster\"})",
          "legendFormat": "Max Age",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Replication Jobs",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 10 },
      "options": {
        "sortBy": [{ "displayName": "Failed", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last Sync Age (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "Duration (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "Next In (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_replication_info{cluster=~\"$cluster\"} * on(cluster,guest) group_left(name) label_replace(pve_guest_info{cluster=~\"$cluster\"}, \"guest\", \"$1\", \"id\", \"(.+)\")",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "INFO"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_replication_failed_syncs{cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "FAILED"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_replication_duration_seconds{cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "DUR"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "time() - pve_replication_last_sync_timestamp_seconds{cluster=~\"$cluster\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "LAST"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pve_replication_next_sync_timestamp_seconds{cluster=~\"$cluster\"} - time()",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "NEXT"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "__name__ 5": true,
              "cluster": true,
              "cluster 1": true,
              "cluster 2": true,
              "cluster 3": true,
              "cluster 4": true,
              "cluster 5": true,
              "Value #INFO": true
            },
            "renameByName": {
              "id": "Job ID",
              "guest": "Guest",
              "name": "Name",
              "source": "Source",
              "target": "Target",
              "Value #FAILED": "Failed",
              "Value #DUR": "Duration (s)",
              "Value #LAST": "Last Sync Age (s)",
              "Value #NEXT": "Next In (s)"
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Replication Last Sync Age",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "time() - pve_replication_last_sync_timestamp_seconds{cluster=~\"$cluster\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Subscription",
      "id": 9,
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Subscription Expiry",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 8 },
      "options": {
        "sortBy": [{ "displayName": "Days Until Due", "desc": false }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Seconds Until Due" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 2592000 },
                    { "color": "green", "value": 5184000 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(pve_subscription_next_due_timestamp_seconds{cluster=~\"$cluster\"} - time()) * on(cluster,id) group_left(name) pve_node_info",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster": true,
              "id": true
            },
            "renameByName": {
              "name": "Node",
              "Value #A": "Seconds Until Due"
            }
          }
        }
      ]
    }
  ]
}
